# ──────────────────────────────────────────────────────────────────────────────
# TEAM CCTV Platform — Environment Variables Template
# ──────────────────────────────────────────────────────────────────────────────
# 1. Copy this file to .env.local (never commit .env.local to version control)
# 2. Fill in all values from your Firebase project console
# 3. Restart the dev server after making changes
# ──────────────────────────────────────────────────────────────────────────────

# ─── FIREBASE CLIENT SDK (NEXT_PUBLIC_ prefix = safe to ship to browser) ──────
# Found in: Firebase Console → Project Settings → Your Apps → Web App Config

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# ─── FIREBASE ADMIN SDK (SERVER-SIDE ONLY — NEVER prefix with NEXT_PUBLIC_) ───
# Found in: Firebase Console → Project Settings → Service Accounts → Generate Key
# IMPORTANT: Paste the private_key value including -----BEGIN/END----- lines.
# Replace all literal newlines in the key with \n so it fits on one line.

FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com

# ─── APP CONFIG ───────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── ANALYTICS & MARKETING ──────────────────────────────────────────────────

NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=123456789012345
