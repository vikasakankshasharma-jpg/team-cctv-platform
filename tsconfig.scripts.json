{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "outDir": "./.tmp-scripts",
    "noEmit": false,
    "isolatedModules": false,
    "paths": {}
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules"]
}
